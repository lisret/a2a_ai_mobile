{
  "extends": "@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "types": ["jest"],
    "baseUrl": ".",
    "module": "esnext",
    "paths": {
      "@core/*": ["src/core/*"],
      "@features/*": ["src/features/*"],
      "@shared/*": ["src/shared/*"],
      "@navigation/*": ["src/navigation/*"]
    }
  },
  "include": [
    "src/**/*",
    "__tests__/**/*",
    "**/__tests__/**/*"
  ]
}
